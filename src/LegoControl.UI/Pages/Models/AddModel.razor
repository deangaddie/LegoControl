@page "/models/add"
@inject ILegoModelService ModelService
@inject NavigationManager Nav
@using System.Text.Json
@using System.Text.Json.Serialization

<PageTitle>Add Model</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Add Model</MudText>

<MudStack Style="max-width: 560px;" Spacing="4">
    <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="false">

        <MudTabPanel Text="Upload JSON">
            <MudStack Spacing="4" Class="pt-4">
                <MudAlert Severity="Severity.Info">
                    Upload a <code>.json</code> file defining a Lego model. The file should specify the model name,
                    set number, connection instructions, and default motor/sensor configuration.
                </MudAlert>

                <InputFile OnChange="OnFileSelected" accept=".json" />

                @if (_uploadError is not null)
                {
                    <MudAlert Severity="Severity.Error">@_uploadError</MudAlert>
                }

                @if (_preview is not null)
                {
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@_preview.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">#@_preview.SetNumber</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @_preview.DefaultConfig.Motors.Count motor(s), @_preview.DefaultConfig.Sensors.Count sensor(s)
                            </MudText>
                        </MudCardContent>
                    </MudCard>

                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveUpload">Add Model</MudButton>
                        <MudButton Variant="Variant.Text" OnClick="@(() => Nav.NavigateTo("/models"))">Cancel</MudButton>
                    </MudStack>
                }
                else
                {
                    <MudButton Variant="Variant.Text" OnClick="@(() => Nav.NavigateTo("/models"))">Cancel</MudButton>
                }
            </MudStack>
        </MudTabPanel>

        <MudTabPanel Text="Configure Manually">
            <MudStack Spacing="4" Class="pt-4">
                <MudTextField @bind-Value="_name" Label="Name" Variant="Variant.Outlined" Required="true" />
                <MudTextField @bind-Value="_setNumber" Label="Set Number" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_instructions" Label="Connection Instructions (one per line)"
                              Variant="Variant.Outlined" Lines="4" />

                <MudDivider />

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1">Motors</MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined"
                               Size="Size.Small" OnClick="AddMotor">Add Motor</MudButton>
                </MudStack>

                @for (var i = 0; i < _motors.Count; i++)
                {
                    var idx = i;
                    <MudPaper Outlined="true" Class="pa-3">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Motor @(idx + 1)</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                               Size="Size.Small" OnClick="@(() => RemoveMotor(idx))" />
                            </MudStack>
                            <MudGrid Spacing="2">
                                <MudItem xs="6">
                                    <MudTextField @bind-Value="_motors[idx].PortId" Label="Port ID"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6">
                                    <MudTextField @bind-Value="_motors[idx].Label" Label="Label"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudSelect @bind-Value="_motors[idx].Role" Label="Role"
                                               Variant="Variant.Outlined" Margin="Margin.Dense">
                                        @foreach (var role in Enum.GetValues<MotorRole>())
                                        {
                                            <MudSelectItem Value="role">@role</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>
                }

                <MudDivider />

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1">Sensors</MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined"
                               Size="Size.Small" OnClick="AddSensor">Add Sensor</MudButton>
                </MudStack>

                @for (var i = 0; i < _sensors.Count; i++)
                {
                    var idx = i;
                    <MudPaper Outlined="true" Class="pa-3">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Sensor @(idx + 1)</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                               Size="Size.Small" OnClick="@(() => RemoveSensor(idx))" />
                            </MudStack>
                            <MudGrid Spacing="2">
                                <MudItem xs="6">
                                    <MudTextField @bind-Value="_sensors[idx].PortId" Label="Port ID"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6">
                                    <MudTextField @bind-Value="_sensors[idx].Label" Label="Label"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudSelect @bind-Value="_sensors[idx].Mode" Label="Mode"
                                               Variant="Variant.Outlined" Margin="Margin.Dense">
                                        @foreach (var mode in Enum.GetValues<SensorMode>())
                                        {
                                            <MudSelectItem Value="mode">@mode</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>
                }

                @if (_manualError is not null)
                {
                    <MudAlert Severity="Severity.Error">@_manualError</MudAlert>
                }

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveManual">Add Model</MudButton>
                    <MudButton Variant="Variant.Text" OnClick="@(() => Nav.NavigateTo("/models"))">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudTabPanel>

    </MudTabs>
</MudStack>

@code {
    // Upload tab state
    private LegoModel? _preview;
    private string? _uploadError;

    // Manual tab state
    private string _name = "";
    private string _setNumber = "";
    private string _instructions = "";
    private List<MotorConfig> _motors = [];
    private List<SensorConfig> _sensors = [];
    private string? _manualError;

    private static readonly JsonSerializerOptions Options = new()
    {
        PropertyNameCaseInsensitive = true,
        Converters = { new JsonStringEnumConverter() }
    };

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _preview = null;
        _uploadError = null;

        var file = e.File;
        if (file is null) return;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024);
            var model = await JsonSerializer.DeserializeAsync<LegoModel>(stream, Options);

            if (model is null || string.IsNullOrWhiteSpace(model.Name))
            {
                _uploadError = "Invalid model file: name is required.";
                return;
            }

            if (model.DefaultConfig.Motors.Count == 0)
            {
                _uploadError = "Invalid model file: at least one motor is required.";
                return;
            }

            _preview = model;
        }
        catch (Exception ex)
        {
            _uploadError = $"Could not parse file: {ex.Message}";
        }
    }

    private async Task SaveUpload()
    {
        if (_preview is null) return;

        _preview.Id = Guid.NewGuid().ToString();
        _preview.IsBuiltIn = false;
        await ModelService.AddAsync(_preview);
        Nav.NavigateTo("/models");
    }

    private void AddMotor() => _motors.Add(new MotorConfig());
    private void RemoveMotor(int index) => _motors.RemoveAt(index);
    private void AddSensor() => _sensors.Add(new SensorConfig());
    private void RemoveSensor(int index) => _sensors.RemoveAt(index);

    private async Task SaveManual()
    {
        _manualError = null;

        if (string.IsNullOrWhiteSpace(_name))
        {
            _manualError = "Name is required.";
            return;
        }

        if (_motors.Count == 0)
        {
            _manualError = "At least one motor is required.";
            return;
        }

        var model = new LegoModel
        {
            Id = Guid.NewGuid().ToString(),
            Name = _name.Trim(),
            SetNumber = _setNumber.Trim(),
            ConnectionInstructions = _instructions
                .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList(),
            DefaultConfig = new DeviceConfig
            {
                Motors = _motors,
                Sensors = _sensors
            },
            IsBuiltIn = false
        };

        await ModelService.AddAsync(model);
        Nav.NavigateTo("/models");
    }
}
