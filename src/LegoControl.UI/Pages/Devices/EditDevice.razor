@page "/devices/edit/{Id:guid}"
@inject IDeviceService DeviceService
@inject ILegoModelService ModelService
@inject NavigationManager Nav

<PageTitle>Edit Device</PageTitle>

@if (_device is null)
{
    <MudAlert Severity="Severity.Error">Device not found.</MudAlert>
}
else
{
    <MudText Typo="Typo.h4" GutterBottom="true">Edit Device</MudText>

    <MudStack Style="max-width: 480px;" Spacing="4">
        <MudTextField @bind-Value="_name" Label="Device Name" Variant="Variant.Outlined" />

        <MudSelect @bind-Value="_modelId" Label="Lego Set" Variant="Variant.Outlined" T="string">
            @foreach (var model in ModelService.Models)
            {
                <MudSelectItem Value="@model.Id">@model.Name (#@model.SetNumber)</MudSelectItem>
            }
        </MudSelect>

        @if (_showError)
        {
            <MudAlert Severity="Severity.Error">Please enter a device name.</MudAlert>
        }

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save</MudButton>
            <MudButton Variant="Variant.Text" OnClick="@(() => Nav.NavigateTo("/devices"))">Cancel</MudButton>
        </MudStack>
    </MudStack>

    @if (_device.Config.Motors.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mt-6 mb-2">Motors</MudText>
        <MudGrid>
            @foreach (var motor in _device.Config.Motors)
            {
                var linkedMotor = _device.Config.Motors.FirstOrDefault(m => m.PortId == motor.LinkedPortId);
                <MudItem xs="12" sm="6" md="4">
                    <MudCard>
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Port @motor.PortId</MudText>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@motor.Role</MudChip>
                            </MudStack>
                            <MudText Typo="Typo.body1" Class="mt-1"><strong>@motor.Label</strong></MudText>
                            @if (motor.InvertDirection)
                            {
                                <MudChip T="string" Icon="@Icons.Material.Filled.SwapVert" Size="Size.Small"
                                         Color="Color.Default" Class="mt-1">Inverted</MudChip>
                            }
                            @if (linkedMotor is not null)
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" Color="Color.Info" />
                                    <MudText Typo="Typo.body2" Color="Color.Info">
                                        Linked to Port @linkedMotor.PortId (@linkedMotor.Label)
                                        @if (motor.InvertLink)
                                        {
                                            <span> — inverted</span>
                                        }
                                    </MudText>
                                </MudStack>
                            }
                            @if (_device.Config.Motors.Any(m => m.LinkedPortId == motor.PortId))
                            {
                                <MudChip T="string" Icon="@Icons.Material.Filled.Link" Color="Color.Info"
                                         Size="Size.Small" Class="mt-1">Follower</MudChip>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }

    @if (_device.Config.Sensors.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mt-4 mb-2">Sensors</MudText>
        <MudGrid>
            @foreach (var sensor in _device.Config.Sensors)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Port @sensor.PortId</MudText>
                            <MudText Typo="Typo.body1" Class="mt-1"><strong>@sensor.Label</strong></MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="mt-1">@sensor.Mode</MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Device? _device;
    private string _name = string.Empty;
    private string _modelId = string.Empty;
    private bool _showError;

    protected override void OnParametersSet()
    {
        _device = DeviceService.Devices.FirstOrDefault(d => d.Id == Id);
        if (_device is not null)
        {
            _name = _device.Name;
            _modelId = _device.ModelId;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _showError = true;
            return;
        }

        await DeviceService.UpdateAsync(Id, _name.Trim(), _modelId);
        Nav.NavigateTo("/devices");
    }
}
