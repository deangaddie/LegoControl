@page "/devices"
@inject IDeviceService DeviceService
@inject ILegoModelService ModelService
@inject NavigationManager Nav
@inject IDialogService DialogService

<PageTitle>Devices</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">My Devices</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Nav.NavigateTo("/devices/add"))">
        Add Device
    </MudButton>
</MudStack>

@if (!DeviceService.Devices.Any())
{
    <MudAlert Severity="Severity.Info" Class="mt-4">
        No devices added yet. Click <strong>Add Device</strong> to get started.
    </MudAlert>
}
else
{
    <MudGrid>
        @foreach (var device in DeviceService.Devices)
        {
            var d = device;
            <MudItem xs="12" sm="6" md="4">
                <MudCard Class="mud-theme-transition">
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@d.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@ModelLabel(d.ModelId)</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudTooltip Text="Play">
                            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success"
                                           OnClick="@(() => Nav.NavigateTo($"/devices/play/{d.Id}"))" />
                        </MudTooltip>
                        <MudTooltip Text="Program">
                            <MudIconButton Icon="@Icons.Material.Filled.Code" Color="Color.Info"
                                           OnClick="@(() => Nav.NavigateTo($"/devices/program/{d.Id}"))" />
                        </MudTooltip>
                        <MudTooltip Text="Configure">
                            <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                           OnClick="@(() => Nav.NavigateTo($"/devices/configure/{d.Id}"))" />
                        </MudTooltip>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => Nav.NavigateTo($"/devices/edit/{d.Id}"))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                       OnClick="@(() => ConfirmDelete(d))" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private string ModelLabel(string modelId)
    {
        var m = ModelService.Models.FirstOrDefault(m => m.Id == modelId);
        return m is not null ? $"{m.Name} (#{m.SetNumber})" : modelId;
    }

    private async Task ConfirmDelete(Device device)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(
            "Delete Device",
            new DialogParameters
            {
                { "ContentText", $"Are you sure you want to delete '{device.Name}'? This action cannot be undone." },
                { "ButtonText", "Delete" },
                { "Color", Color.Error }
            });

        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await DeviceService.RemoveAsync(device.Id);
        }
    }
}