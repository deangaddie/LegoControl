@page "/devices/play/{Id:guid}/touch"
@layout FullScreenLayout
@inject IDeviceService DeviceService
@inject ILegoModelService ModelService
@inject IBluetoothService BluetoothService
@inject ILegoHubService HubService
@inject NavigationManager Nav
@implements IAsyncDisposable

<div style="display: flex; flex-direction: column; height: 100%; background: #111; color: #fff; font-family: sans-serif;">

    <!-- Top status bar -->
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 8px 16px; background: rgba(0,0,0,0.4); flex-shrink: 0;">
        <button style="@BackButtonStyle" @onclick="GoBack">&#8592; Back</button>

        <span style="font-size: 14px; font-weight: 600; opacity: 0.9;">@(_device?.Name ?? "Play")</span>

        <div style="display: flex; align-items: center; gap: 8px;">
            @if (BluetoothService.IsConnected)
            {
                <span style="font-size: 12px; color: #66bb6a;">&#9679; @BluetoothService.ConnectedDeviceName</span>
            }
            else
            {
                <span style="font-size: 12px; color: #ef5350;">&#9679; Disconnected</span>
            }
        </div>
    </div>

    @if (!BluetoothService.IsConnected)
    {
        <div style="flex: 1; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 16px;">
            <span style="opacity: 0.5; font-size: 18px;">Not connected</span>
            <span style="opacity: 0.4; font-size: 13px;">Connect via the device page</span>
        </div>
    }
    else
    {
        <!-- Main control area -->
        <div style="flex: 1; display: flex; min-height: 0; padding: 16px; gap: 16px;">

            <!-- Left pad: throttle (vertical) -->
            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8px;">
                <span style="font-size: 11px; opacity: 0.5; text-transform: uppercase; letter-spacing: 1px;">Throttle</span>
                <div style="flex: 1; width: 100%; max-width: 200px; aspect-ratio: 1; position: relative;">
                    <!-- Vertical guide line -->
                    <div style="position: absolute; top: 0; bottom: 0; left: 50%; width: 1px; background: rgba(255,255,255,0.1);"></div>
                    <div style="position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: rgba(255,255,255,0.1);"></div>
                    <TouchJoystick Axis="TouchJoystick.JoystickAxis.Vertical"
                                   ValueChanged="OnThrottleChanged" />
                </div>
                <div style="font-size: 12px; opacity: 0.6;">
                    <span style="color: #ffd54f;">@_throttlePercent%</span>
                </div>
            </div>

            <!-- Centre feedback overlay -->
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; min-width: 80px; overflow: hidden;">
                <MotorFeedbackPanel Motors="_motors"
                                    HubService="HubService"
                                    RequestedSpeeds="_requestedSpeeds"
                                    RequestedPositions="_requestedPositions"
                                    Style="flex-direction: column; align-items: center;" />
            </div>

            <!-- Right pad: steering (horizontal) -->
            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8px;">
                <span style="font-size: 11px; opacity: 0.5; text-transform: uppercase; letter-spacing: 1px;">Steering</span>
                <div style="flex: 1; width: 100%; max-width: 200px; aspect-ratio: 1; position: relative;">
                    <div style="position: absolute; top: 0; bottom: 0; left: 50%; width: 1px; background: rgba(255,255,255,0.1);"></div>
                    <div style="position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: rgba(255,255,255,0.1);"></div>
                    <TouchJoystick Axis="TouchJoystick.JoystickAxis.Horizontal"
                                   ValueChanged="OnSteerChanged" />
                </div>
                <div style="font-size: 12px; opacity: 0.6;">
                    <span style="color: #ffd54f;">@_steerDegrees°</span>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private Device? _device;
    private LegoModel? _model;
    private List<MotorConfig> _motors = [];

    private readonly Dictionary<string, int> _requestedSpeeds = new();
    private readonly Dictionary<string, int> _requestedPositions = new();

    private int _throttlePercent = 0;
    private int _steerDegrees = 0;

    // Rate-limit timer
    private PeriodicTimer? _commandTimer;
    private Task? _commandLoopTask;
    private float _lastThrottle = 0f;
    private float _lastSteer = 0f;

    private string BackButtonStyle =>
        "background: rgba(255,255,255,0.1); border: none; color: #fff; padding: 6px 12px; " +
        "border-radius: 6px; font-size: 14px; cursor: pointer;";

    protected override void OnParametersSet()
    {
        _device = DeviceService.Devices.FirstOrDefault(d => d.Id == Id);
        if (_device is null) return;

        _model = ModelService.Models.FirstOrDefault(m => m.Id == _device.ModelId);
        _motors = _device.Config.Motors.Select(m => new MotorConfig
        {
            PortId = m.PortId, Label = m.Label, Role = m.Role,
            InvertDirection = m.InvertDirection, LinkedPortId = m.LinkedPortId, InvertLink = m.InvertLink,
            MinSpeed = m.MinSpeed, MaxSpeed = m.MaxSpeed,
            SteeringMaxLeft = m.SteeringMaxLeft, SteeringMaxRight = m.SteeringMaxRight,
        }).ToList();

        foreach (var m in _motors)
        {
            _requestedSpeeds.TryAdd(m.PortId, 0);
            _requestedPositions.TryAdd(m.PortId, 0);
        }

        BluetoothService.ConnectionStateChanged += OnConnectionStateChanged;
        HubService.MotorSpeedChanged += OnMotorFeedbackChanged;
        HubService.MotorPositionChanged += OnMotorFeedbackChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        if (BluetoothService.IsConnected)
        {
            foreach (var m in _motors)
            {
                if (m.Role == MotorRole.Steering)
                    await HubService.SubscribeMotorPositionAsync(m.PortId);
                else
                    await HubService.SubscribeMotorSpeedAsync(m.PortId);
            }
        }
    }

    private void OnConnectionStateChanged() => InvokeAsync(async () =>
    {
        StateHasChanged();
        if (BluetoothService.IsConnected)
        {
            foreach (var m in _motors)
            {
                if (m.Role == MotorRole.Steering)
                    await HubService.SubscribeMotorPositionAsync(m.PortId);
                else
                    await HubService.SubscribeMotorSpeedAsync(m.PortId);
            }
        }
    });

    private void OnMotorFeedbackChanged(string _, int __) => InvokeAsync(StateHasChanged);

    private void OnThrottleChanged(float value)
    {
        _lastThrottle = value;
        EnsureCommandLoop();
    }

    private void OnSteerChanged(float value)
    {
        _lastSteer = value;
        EnsureCommandLoop();
    }

    private void EnsureCommandLoop()
    {
        if (_commandTimer is not null) return;
        _commandTimer = new PeriodicTimer(TimeSpan.FromMilliseconds(50)); // 20 Hz
        _commandLoopTask = RunCommandLoop();
    }

    private async Task RunCommandLoop()
    {
        while (_commandTimer is not null && await _commandTimer.WaitForNextTickAsync())
        {
            if (!BluetoothService.IsConnected) continue;
            await SendDriveAsync(_lastThrottle);
            await SendSteerAsync(_lastSteer);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SendDriveAsync(float throttle)
    {
        foreach (var motor in _motors.Where(m => m.Role is MotorRole.Drive or MotorRole.Auxiliary))
        {
            if (_motors.Any(m => m.LinkedPortId == motor.PortId)) continue;

            int speed = (int)Math.Round(throttle * motor.MaxSpeed);
            if (speed != 0 && Math.Abs(speed) < motor.MinSpeed)
                speed = motor.MinSpeed * Math.Sign(speed);

            _requestedSpeeds[motor.PortId] = speed;
            _throttlePercent = speed;

            int actual = motor.InvertDirection ? -speed : speed;
            await BluetoothService.SendCommandAsync(LegoCommandBuilder.StartPower(motor.PortId, actual));

            if (motor.LinkedPortId is not null)
            {
                var linked = _motors.FirstOrDefault(m => m.PortId == motor.LinkedPortId);
                if (linked is not null)
                {
                    int linkedRaw = motor.InvertLink ? -actual : actual;
                    int linkedActual = linked.InvertDirection ? -linkedRaw : linkedRaw;
                    _requestedSpeeds[linked.PortId] = linkedActual;
                    await BluetoothService.SendCommandAsync(LegoCommandBuilder.StartPower(linked.PortId, linkedActual));
                }
            }
        }
    }

    private async Task SendSteerAsync(float axis)
    {
        foreach (var motor in _motors.Where(m => m.Role == MotorRole.Steering))
        {
            int degrees = axis >= 0
                ? (int)Math.Round(axis * motor.SteeringMaxRight)
                : (int)Math.Round(axis * Math.Abs(motor.SteeringMaxLeft));

            _requestedPositions[motor.PortId] = degrees;
            _steerDegrees = degrees;

            int actual = motor.InvertDirection ? -degrees : degrees;
            await BluetoothService.SendCommandAsync(LegoCommandBuilder.GoToAbsolutePosition(motor.PortId, actual));
        }
    }

    private void GoBack() => Nav.NavigateTo($"/devices/play/{Id}");

    public async ValueTask DisposeAsync()
    {
        BluetoothService.ConnectionStateChanged -= OnConnectionStateChanged;
        HubService.MotorSpeedChanged -= OnMotorFeedbackChanged;
        HubService.MotorPositionChanged -= OnMotorFeedbackChanged;

        _commandTimer?.Dispose();
        _commandTimer = null;
        if (_commandLoopTask is not null)
            await _commandLoopTask.ConfigureAwait(false);

        if (BluetoothService.IsConnected)
        {
            foreach (var m in _motors.Where(m => m.Role != MotorRole.Steering))
                await BluetoothService.SendCommandAsync(LegoCommandBuilder.StartPower(m.PortId, 0));
        }
    }
}
