@inject IJSRuntime JS
@implements IAsyncDisposable

<div @ref="_padRef"
     style="@PadStyle"
     @onpointerdown="OnPointerDown"
     @onpointermove="OnPointerMove"
     @onpointerup="OnPointerUp"
     @onpointercancel="OnPointerUp">
    <div style="@ThumbStyle"></div>
</div>

@code {
    public enum JoystickAxis { Vertical, Horizontal }

    [Parameter, EditorRequired] public JoystickAxis Axis { get; set; }
    [Parameter] public EventCallback<float> ValueChanged { get; set; }
    [Parameter] public string Style { get; set; } = "";

    private ElementReference _padRef;
    private IJSObjectReference? _jsModule;

    private float _thumbX = 0f;
    private float _thumbY = 0f;
    private bool _active = false;
    private long _capturedPointerId = -1;

    // Pad bounding rect cached on first pointer down
    private double _padCx, _padCy, _padHW, _padHH;

    private const float DeadZone = 0.10f;

    private string PadStyle =>
        "position: relative; width: 100%; height: 100%; " +
        "border-radius: 50%; background: rgba(255,255,255,0.08); " +
        "border: 2px solid rgba(255,255,255,0.20); touch-action: none; user-select: none; " + Style;

    private string ThumbStyle
    {
        get
        {
            var xPct = 50.0 + _thumbX * 40.0;
            var yPct = 50.0 + _thumbY * 40.0;
            var transition = _active ? "none" : "top 0.15s, left 0.15s";
            return $"position: absolute; width: 40%; height: 40%; border-radius: 50%; " +
                   $"background: rgba(255,255,255,0.75); box-shadow: 0 2px 8px rgba(0,0,0,0.4); " +
                   $"top: {yPct.ToString("F1", CultureInfo.InvariantCulture)}%; left: {xPct.ToString("F1", CultureInfo.InvariantCulture)}%; transform: translate(-50%,-50%); " +
                   $"pointer-events: none; transition: {transition};";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/lego-bluetooth.js");
    }

    private async Task OnPointerDown(PointerEventArgs e)
    {
        _active = true;
        _capturedPointerId = e.PointerId;

        if (_jsModule is not null)
        {
            await _jsModule.InvokeVoidAsync("capturePointer", _padRef, (int)e.PointerId);
            var rect = await _jsModule.InvokeAsync<BoundingRect>("getBoundingRect", _padRef);
            _padCx = rect.Left + rect.Width / 2.0;
            _padCy = rect.Top + rect.Height / 2.0;
            _padHW = rect.Width / 2.0;
            _padHH = rect.Height / 2.0;
        }

        UpdateThumb(e.ClientX, e.ClientY);
        await EmitValue();
    }

    private async Task OnPointerMove(PointerEventArgs e)
    {
        if (!_active || e.PointerId != _capturedPointerId) return;
        UpdateThumb(e.ClientX, e.ClientY);
        await EmitValue();
    }

    private void UpdateThumb(double clientX, double clientY)
    {
        var hw = _padHW > 0 ? _padHW : 75.0;
        var hh = _padHH > 0 ? _padHH : 75.0;

        var dx = (clientX - _padCx) / hw;
        var dy = (clientY - _padCy) / hh;

        var len = Math.Sqrt(dx * dx + dy * dy);
        if (len > 1.0) { dx /= len; dy /= len; }

        _thumbX = Axis == JoystickAxis.Vertical ? 0f : (float)dx;
        _thumbY = Axis == JoystickAxis.Horizontal ? 0f : (float)dy;
    }

    private async Task OnPointerUp(PointerEventArgs e)
    {
        if (!_active) return;
        _active = false;
        _capturedPointerId = -1;
        _thumbX = 0f;
        _thumbY = 0f;
        await EmitValue();
    }

    private async Task EmitValue()
    {
        StateHasChanged();
        // Up = positive throttle (negate Y since screen Y grows downward)
        float raw = Axis == JoystickAxis.Horizontal ? _thumbX : -_thumbY;
        float value = Math.Abs(raw) < DeadZone ? 0f : raw;
        await ValueChanged.InvokeAsync(value);
    }

    private record BoundingRect(double Left, double Top, double Width, double Height);

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
            await _jsModule.DisposeAsync();
    }
}
