@inherits LayoutComponentBase
@inject IDeviceService DeviceService
@inject ILegoModelService ModelService
@inject IJSRuntime JS

<MudThemeProvider IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PwaUpdateChecker />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6">LegoControl</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleTheme" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @if (_initialized)
            {
                @Body
            }
            else
            {
                <MudProgressCircular Indeterminate="true" />
            }
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private const string ThemeKey = "lc_darkmode";

    bool _drawerOpen = true;
    bool _isDarkMode = false;
    bool _initialized = false;

    void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnInitializedAsync()
    {
        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", ThemeKey);
        _isDarkMode = stored == "true";

        await ModelService.InitializeAsync();
        await DeviceService.InitializeAsync();
        _initialized = true;
    }

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", ThemeKey, _isDarkMode ? "true" : "false");
    }
}
