@inherits LayoutComponentBase
@implements IDisposable
@inject IDeviceService DeviceService
@inject ILegoModelService ModelService
@inject IThemeService ThemeService
@inject NavigationManager Nav

<MudThemeProvider Theme="@ThemeService.Theme" IsDarkMode="@ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PwaUpdateChecker />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6">LegoControl</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleDarkMode" />
        <MudIconButton Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit"
                       OnClick="@(() => Nav.NavigateTo("settings"))" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @if (_initialized)
            {
                @Body
            }
            else
            {
                <MudProgressCircular Indeterminate="true" />
            }
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _initialized = false;

    void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync();
        ThemeService.OnChanged += OnThemeChanged;

        await ModelService.InitializeAsync();
        await DeviceService.InitializeAsync();
        _initialized = true;
    }

    private async Task ToggleDarkMode() =>
        await ThemeService.SetDarkModeAsync(!ThemeService.IsDarkMode);

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => ThemeService.OnChanged -= OnThemeChanged;
}
