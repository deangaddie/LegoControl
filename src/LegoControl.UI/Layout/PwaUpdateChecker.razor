@inject IJSRuntime JS
@implements IAsyncDisposable

@if (_updateAvailable)
{
    <MudAlert Severity="Severity.Info" Dense="true" Square="true" Class="pwa-update-banner"
              Icon="@Icons.Material.Filled.SystemUpdate">
        A new version is available.
        <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                   OnClick="ApplyUpdate">Refresh</MudButton>
    </MudAlert>
}

@code {
    private IJSObjectReference? _module;
    private DotNetObjectReference<PwaUpdateChecker>? _self;
    private bool _updateAvailable;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/pwa-registration.js");
        _self = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("registerAndWatch", _self);
    }

    [JSInvokable]
    public void OnUpdateAvailable()
    {
        _updateAvailable = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task ApplyUpdate()
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("applyUpdate");
    }

    public async ValueTask DisposeAsync()
    {
        _self?.Dispose();
        if (_module is not null)
            await _module.DisposeAsync();
    }
}
