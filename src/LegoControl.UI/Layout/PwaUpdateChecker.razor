@inject IJSRuntime JS
@implements IAsyncDisposable

@if (_updateAvailable)
{
    <div class="pwa-update-toast">
        <MudPaper Elevation="12" Class="pwa-update-card">
            <MudIcon Icon="@Icons.Material.Filled.SystemUpdateAlt" Class="pwa-update-icon" />
            <div class="pwa-update-text">
                <MudText Typo="Typo.subtitle2" Style="font-weight:700;line-height:1.2;">Update ready</MudText>
                <MudText Typo="Typo.caption" Style="opacity:0.65;line-height:1.3;">A new version of LegoControl is available.</MudText>
            </div>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="ApplyUpdate">
                Update
            </MudButton>
        </MudPaper>
    </div>
}

@code {
    private IJSObjectReference? _module;
    private DotNetObjectReference<PwaUpdateChecker>? _self;
    private bool _updateAvailable;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/pwa-registration.js");
        _self = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("registerAndWatch", _self);
    }

    [JSInvokable]
    public void OnUpdateAvailable()
    {
        _updateAvailable = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task ApplyUpdate()
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("applyUpdate");
    }

    public async ValueTask DisposeAsync()
    {
        _self?.Dispose();
        if (_module is not null)
            await _module.DisposeAsync();
    }
}
