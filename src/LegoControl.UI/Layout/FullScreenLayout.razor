@inherits LayoutComponentBase
@implements IDisposable
@inject IDeviceService DeviceService
@inject ILegoModelService ModelService
@inject IThemeService ThemeService

<MudThemeProvider Theme="@ThemeService.Theme" IsDarkMode="@ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div style="position: fixed; inset: 0; background: var(--mud-palette-background); overflow: hidden;">
    @if (_initialized)
    {
        @Body
    }
    else
    {
        <MudProgressCircular Indeterminate="true" />
    }
</div>

@code {
    private bool _initialized = false;

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync();
        ThemeService.OnChanged += OnThemeChanged;

        await ModelService.InitializeAsync();
        await DeviceService.InitializeAsync();
        _initialized = true;
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => ThemeService.OnChanged -= OnThemeChanged;
}
